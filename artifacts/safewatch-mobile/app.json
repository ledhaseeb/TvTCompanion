{
  "expo": {
    "name": "SafeWatch",
    "slug": "safewatch-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "safewatch-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.safewatch.mobile"
    },
    "android": {
      "package": "com.safewatch.mobile"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "react-native-google-cast",
        {
          "iosReceiverAppId": "0F5E0B59",
          "androidReceiverAppId": "0F5E0B59"
        }
      ],
      "./plugins/withCastFrameworkVersion"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "aa6bf470-e46f-4e73-ba53-65b18952a7d3"
      }
    }
  }
}
